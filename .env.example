# Copy to .env and adjust. All optional — sane defaults are built in.

# Where finished CBZs are written (point at Tome's Bindery / library mount).
OUTPUT_DIR=./data/output
# Working area for in-progress page downloads.
STAGING_DIR=./data/staging
# SQLite database file.
DB_PATH=./data/mangas-binder.db

# HTTP server.
PORT=8787
HOST=0.0.0.0
# Set to require auth (Bearer token or ?token=). Empty = no auth.
AUTH_TOKEN=

# Scheduler / pipeline defaults (also editable in the UI).
SCAN_INTERVAL_HOURS=6
DOWNLOAD_CONCURRENCY=4           # parallel page fetches within a chapter
CHAPTER_CONCURRENCY=2           # chapters downloaded in parallel (be polite)
DEFAULT_PACKAGING_MODE=volume   # volume | chapter
DEFAULT_MONITOR_MODE=all        # all | future | none
DEFAULT_LANGUAGE=en
DATA_SAVER=false                # use MangaDex data-saver (smaller) images
KEEP_LOOSE_PAGES=false          # keep staged page images after binding
EXTRAPOLATE_VOLUMES=true        # assign untagged chapters to estimated volumes

# Notifications (empty = disabled). Also editable in the UI.
DISCORD_WEBHOOK=                # Discord webhook URL
NTFY_URL=                       # full ntfy topic URL, e.g. https://ntfy.sh/my-topic
NOTIFY_ON_IMPORT=true           # notify when a volume/chapter is added
NOTIFY_ON_ERROR=false           # notify on repeated download/bind failures
