# Copy to .env and adjust. All optional — sane defaults are built in.

# Where finished CBZs are written (point at Tome's Bindery / library mount).
OUTPUT_DIR=./data/output
# Working area for in-progress page downloads.
STAGING_DIR=./data/staging
# SQLite database file.
DB_PATH=./data/mangas-binder.db
# Dirs scanned to detect already-owned CBZs (comma-separated; defaults to OUTPUT_DIR).
# Add Tome's library mount (e.g. /books, read-only) if Tome moves files on import.
# LIBRARY_SCAN_DIRS=./data/output,/books

# HTTP server.
PORT=8787
HOST=0.0.0.0
# Set to require auth (Bearer token or ?token=). Empty = no auth.
AUTH_TOKEN=

# Scheduler / pipeline defaults (also editable in the UI).
SCAN_INTERVAL_HOURS=6
DOWNLOAD_CONCURRENCY=4           # parallel page fetches within a chapter
CHAPTER_CONCURRENCY=2           # chapters downloaded in parallel (be polite)
DOWNLOADS_PAUSED=false          # master kill-switch: no downloads/packaging (handy while deploying/testing)
REFRESH_CONCURRENCY=3           # monitored series refreshed in parallel per scan cycle
SERIES_REFRESH_TIMEOUT_SEC=90   # abandon a single series' refresh after this (one stuck source won't stall the cycle)
DEFAULT_PACKAGING_MODE=volume   # volume | chapter
DEFAULT_MONITOR_MODE=all        # all | future | none
DEFAULT_LANGUAGE=en             # default language; French is used as a backup when needed
DATA_SAVER=false                # use MangaDex data-saver (smaller) images
KEEP_LOOSE_PAGES=false          # keep staged page images after binding
EXTRAPOLATE_VOLUMES=true        # assign untagged chapters to estimated volumes

# --- MangaKatana fallback (page source when MangaDex@Home fails) ----------
# MangaKatana is behind Cloudflare, so it needs a FlareSolverr container to clear
# the challenge. Point this at FlareSolverr on a shared Docker network. Empty = disabled.
FLARESOLVERR_URL=               # e.g. http://flaresolverr:8191/v1
MANGA_FALLBACK_ENABLED=false    # when true (+ MangaKatana enabled), retry failed MangaDex pages via MangaKatana

# Notifications (empty = disabled). Also editable in the UI.
DISCORD_WEBHOOK=                # Discord webhook URL
NTFY_URL=                       # full ntfy topic URL, e.g. https://ntfy.sh/my-topic
NOTIFY_ON_IMPORT=true           # notify when a volume/chapter is added
NOTIFY_ON_ERROR=false           # notify on repeated download/bind failures

# --- Comics (in addition to manga) ---------------------------------------
# Comics use ComicVine for metadata (free key: https://comicvine.gamespot.com/api)
# and GetComics for files. Both are also configurable in the UI (Settings → Sources).
COMICVINE_API_KEY=              # seeded into ComicVine provider config on first run
GETCOMICS_BASE_URL=             # optional override, defaults to https://getcomics.org
